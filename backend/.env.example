# Copy to .env and adjust. Host port must match docker-compose published Postgres port
# (default POSTGRES_HOST_PORT=5435 — see repo root docker-compose.yml).

DATABASE_URL=postgresql://notebooksocial:notebooksocial_password@127.0.0.1:5435/notebooksocial
REDIS_URL=redis://127.0.0.1:6379/0
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
SECRET_KEY=dev-secret-key-change-in-production
FRONTEND_URL=http://localhost:3000
ENV=development
